
<!-- saved from url=(0059)file:///Users/victoriafarges/Downloads/domore_platform.html -->
<html><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&family=DM+Serif+Display:ital@0;1&display=swap');
*{box-sizing:border-box;margin:0;padding:0;}
:root{--bg:#050814;--bg2:#0d1b3e;--bg3:#0b1325;--border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.13);--muted:#8899bb;--blue:#38bdf8;--blue-bg:rgba(56,189,248,0.12);--blue-border:rgba(56,189,248,0.25);--green:#34d399;--green-bg:rgba(52,211,153,0.12);--green-border:rgba(52,211,153,0.22);--yellow:#fbbf24;--red:#f87171;--red-bg:rgba(248,113,113,0.12);}
body{font-family:'DM Sans','Helvetica Neue',sans-serif;background:var(--bg);color:#fff;min-height:100vh;}
.orb1{position:fixed;top:-80px;right:10%;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(56,189,248,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;}
.orb2{position:fixed;bottom:-80px;left:5%;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(99,102,241,0.1) 0%,transparent 70%);pointer-events:none;z-index:0;}
.app{position:relative;z-index:1;min-height:100vh;}
.nav{display:flex;align-items:center;justify-content:space-between;padding:14px 28px;background:rgba(5,8,20,0.9);border-bottom:1px solid var(--border);backdrop-filter:blur(8px);position:sticky;top:0;z-index:50;}
.nav-logo{display:flex;align-items:center;gap:10px;}
.logo-mark{background:var(--blue);color:#020e1a;width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:16px;font-family:'DM Serif Display',serif;}
.logo-name{font-size:19px;font-weight:700;color:#fff;letter-spacing:-.5px;}
.logo-ch{background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-border);border-radius:999px;padding:2px 8px;font-size:10px;font-weight:700;}
.nav-center{display:flex;gap:2px;}
.ntab{background:transparent;border:1px solid transparent;border-radius:999px;padding:7px 16px;font-size:13px;color:var(--muted);cursor:pointer;font-family:inherit;transition:all .15s;}
.ntab.active{background:var(--blue-bg);border-color:var(--blue-border);color:var(--blue);}
.ntab:hover:not(.active){background:rgba(255,255,255,0.05);color:#fff;}
.nav-right{display:flex;align-items:center;gap:8px;}
.user-pill{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,0.04);border:1px solid var(--border2);border-radius:999px;padding:5px 12px 5px 5px;font-size:12px;cursor:pointer;color:#fff;}
.user-av{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;}
.role-badge{font-size:10px;padding:3px 10px;border-radius:999px;font-weight:700;cursor:pointer;border:1px solid;}
.role-student{background:var(--green-bg);color:var(--green);border-color:var(--green-border);}
.role-partner{background:var(--blue-bg);color:var(--blue);border-color:var(--blue-border);}
.hero{background:linear-gradient(180deg,#0d1b3e 0%,#060d1f 100%);border-bottom:1px solid var(--border);padding:36px 28px;}
.hero-inner{display:grid;grid-template-columns:1.3fr 0.7fr;gap:36px;align-items:center;max-width:1060px;}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.05);border:1px solid var(--border2);border-radius:999px;padding:5px 14px;font-size:12px;color:#a5b4fc;margin-bottom:16px;}
.hero h1{font-family:'DM Serif Display',Georgia,serif;font-size:36px;line-height:1.12;margin-bottom:12px;color:#fff;}
.hero h1 em{color:var(--blue);font-style:italic;}
.hero p{font-size:14px;color:#c0cfe8;line-height:1.65;margin-bottom:22px;}
.hero-btns{display:flex;gap:10px;flex-wrap:wrap;}
.btn-blue{background:var(--blue);color:#020e1a;border:none;border-radius:10px;padding:10px 20px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.btn-blue:hover{opacity:.85;}
.btn-ghost{background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.3);border-radius:10px;padding:10px 20px;font-size:13px;cursor:pointer;font-family:inherit;transition:background .15s;}
.btn-ghost:hover{background:rgba(255,255,255,0.07);}
.hero-card{background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:20px;padding:22px;}
.hc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.hc-title{font-size:17px;font-weight:700;color:#fff;}
.hc-sub{font-size:11px;color:#a0b4d0;margin-top:2px;}
.shield{width:34px;height:34px;background:var(--blue-bg);border:1px solid var(--blue-border);border-radius:10px;display:flex;align-items:center;justify-content:center;color:var(--blue);font-size:15px;}
.hs-big{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:14px;padding:13px 15px;margin-bottom:9px;}
.hs-big .l{font-size:10px;color:#a0b4d0;text-transform:uppercase;letter-spacing:.07em;}
.hs-big .v{font-size:26px;font-weight:700;color:var(--green);margin-top:3px;}
.hs-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.hs-sm{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:11px 13px;}
.hs-sm .l{font-size:10px;color:#a0b4d0;text-transform:uppercase;letter-spacing:.06em;}
.hs-sm .v{font-size:14px;font-weight:700;margin-top:3px;color:#fff;}
.main{max-width:1060px;padding:26px 28px;position:relative;z-index:1;}
.stat-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:22px;}
.sc{background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:16px;padding:15px 17px;display:flex;align-items:flex-start;justify-content:space-between;}
.sc .ico{width:34px;height:34px;background:rgba(255,255,255,0.05);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.sc .l{font-size:11px;color:#a0b4d0;}
.sc .v{font-size:19px;font-weight:700;color:#fff;margin:2px 0;}
.sc .s{font-size:10px;color:#6a7a99;}
.explorer{background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:20px;padding:20px;}
.ex-title{font-family:'DM Serif Display',Georgia,serif;font-size:21px;margin-bottom:3px;color:#fff;}
.ex-sub{font-size:12px;color:#a0b4d0;margin-bottom:16px;}
.cats{display:flex;gap:6px;margin-bottom:18px;flex-wrap:wrap;}
.cat{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:999px;padding:5px 14px;font-size:12px;font-weight:500;color:#a0b4d0;cursor:pointer;transition:all .15s;font-family:inherit;}
.cat:hover{background:rgba(255,255,255,0.08);color:#fff;}
.cat.active{background:var(--blue-bg);border-color:var(--blue-border);color:var(--blue);}
.cat-all.active{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.2);color:#fff;}
.content-row{display:grid;grid-template-columns:210px 1fr;gap:14px;}
.filters{background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:16px;padding:16px;height:fit-content;}
.f-title{font-size:13px;font-weight:700;color:#fff;margin-bottom:14px;}
.fg{margin-bottom:14px;}
.fl{font-size:10px;color:#a0b4d0;text-transform:uppercase;letter-spacing:.07em;margin-bottom:5px;}
.fr{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.fv{font-size:12px;font-weight:700;color:var(--blue);}
select.ds{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:8px;padding:7px 9px;font-size:12px;color:#fff;font-family:inherit;}
select.ds option{background:#0d1b3e;color:#fff;}
input[type=range]{width:100%;accent-color:var(--blue);}
.search-input{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:8px;padding:7px 9px;font-size:12px;color:#fff;font-family:inherit;}
.search-input::placeholder{color:#6a7a99;}
.results{display:flex;flex-direction:column;gap:11px;}
.results-hdr{display:flex;align-items:center;margin-bottom:6px;}
.results-count{font-size:12px;color:#a0b4d0;}
.act{background:var(--bg3);border:1px solid var(--border);border-radius:17px;overflow:hidden;transition:border-color .2s,transform .18s;}
.act:hover{border-color:rgba(56,189,248,0.28);transform:translateY(-2px);}
.act-inner{display:flex;}
.act-img{width:125px;flex-shrink:0;position:relative;overflow:hidden;}
.act-img img{width:100%;height:100%;object-fit:cover;display:block;}
.img-ov{position:absolute;inset:0;background:linear-gradient(to top,#0b1325 0%,transparent 55%);}
.disc-b{position:absolute;top:8px;left:8px;background:var(--green);color:#022c22;border-radius:999px;padding:2px 8px;font-size:10px;font-weight:800;}
.cat-b{position:absolute;bottom:8px;left:8px;background:rgba(5,8,20,0.8);color:#fff;border-radius:6px;padding:2px 7px;font-size:10px;border:1px solid var(--border2);}
.act-body{flex:1;padding:13px 17px;}
.act-meta{display:flex;align-items:center;gap:7px;margin-bottom:7px;flex-wrap:wrap;}
.city-t{font-size:11px;color:#a0b4d0;}
.rating-t{font-size:12px;font-weight:700;color:var(--yellow);margin-left:auto;}
.act-title{font-size:14px;font-weight:700;color:#fff;margin-bottom:2px;line-height:1.3;}
.act-partner{font-size:11px;color:#a0b4d0;margin-bottom:9px;}
.act-dets{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:11px;}
.det{font-size:11px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:7px;padding:3px 8px;color:#c0cfe8;}
.act-footer{display:flex;align-items:center;justify-content:space-between;}
.pb{display:flex;align-items:baseline;gap:5px;}
.pn{font-size:21px;font-weight:700;color:var(--blue);}
.po{font-size:12px;color:#556b88;text-decoration:line-through;}
.sp-pill{font-size:10px;padding:3px 8px;border-radius:999px;font-weight:700;}
.sp-ok{background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);}
.sp-warn{background:rgba(251,191,36,0.12);color:var(--yellow);border:1px solid rgba(251,191,36,0.22);}
.sp-crit{background:var(--red-bg);color:var(--red);border:1px solid rgba(248,113,113,0.22);}
.book-btn{background:var(--blue);color:#020e1a;border:none;border-radius:9px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.book-btn:hover{opacity:.82;}
.empty{text-align:center;padding:40px 16px;color:#a0b4d0;font-size:14px;line-height:1.6;}
.portal{display:grid;grid-template-columns:280px 1fr;gap:16px;}
.portal-side{display:flex;flex-direction:column;gap:12px;}
.p-profile{background:var(--bg2);border:1px solid var(--border2);border-radius:18px;padding:20px;text-align:center;}
.p-avatar{width:60px;height:60px;border-radius:50%;background:var(--blue-bg);border:2px solid var(--blue-border);display:flex;align-items:center;justify-content:center;font-size:22px;margin:0 auto 12px;}
.p-name{font-size:16px;font-weight:700;color:#fff;margin-bottom:3px;}
.p-city{font-size:12px;color:#a0b4d0;margin-bottom:12px;}
.p-stats-mini{display:grid;grid-template-columns:1fr 1fr;gap:8px;text-align:left;}
.pm-stat{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:10px 12px;}
.pm-stat .v{font-size:17px;font-weight:700;color:var(--blue);}
.pm-stat .l{font-size:10px;color:#a0b4d0;margin-top:1px;}
.portal-main{display:flex;flex-direction:column;gap:14px;}
.form-card{background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:18px;padding:22px;}
.fc-title{font-family:'DM Serif Display',Georgia,serif;font-size:20px;margin-bottom:3px;color:#fff;}
.fc-sub{font-size:12px;color:#a0b4d0;margin-bottom:18px;}
.df{margin-bottom:12px;}
.df label{font-size:11px;color:#a0b4d0;display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em;}
.df input,.df select,.df textarea{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:9px;padding:9px 11px;font-size:13px;color:#fff;font-family:inherit;transition:border-color .15s;}
.df input:focus,.df select:focus,.df textarea:focus{outline:none;border-color:var(--blue);}
.df input::placeholder,.df textarea::placeholder{color:#6a7a99;}
.df select option{background:#0d1b3e;color:#fff;}
.df textarea{min-height:70px;resize:vertical;}
.df-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.df-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.form-btns{display:flex;gap:8px;margin-top:4px;}
.btn-ghost-sm{background:transparent;color:#a0b4d0;border:1px solid var(--border2);border-radius:9px;padding:9px 16px;font-size:13px;cursor:pointer;font-family:inherit;}
.criteria{background:rgba(56,189,248,0.06);border:1px solid var(--blue-border);border-radius:14px;padding:14px 16px;margin-bottom:14px;}
.crit-title{font-size:12px;font-weight:700;color:var(--blue);margin-bottom:10px;}
.crit-item{display:flex;align-items:center;gap:8px;font-size:12px;color:#a0b4d0;margin-bottom:6px;}
.crit-item:last-child{margin-bottom:0;}
.crit-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.15);flex-shrink:0;transition:background .2s;}
.crit-dot.ok{background:var(--green);}
.crit-dot.bad{background:var(--red);}
.offers-list{background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:18px;overflow:hidden;}
.ol-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.ol-title{font-size:15px;font-weight:700;color:#fff;}
.offer-row{padding:13px 18px;border-bottom:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;gap:13px;}
.offer-row:last-child{border-bottom:none;}
.or-ico{width:34px;height:34px;background:rgba(255,255,255,0.05);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.or-info{flex:1;}
.or-info .t{font-size:13px;font-weight:700;color:#fff;}
.or-info .s{font-size:11px;color:#a0b4d0;margin-top:1px;}
.or-stats{text-align:right;min-width:80px;}
.or-stats .p{font-size:13px;font-weight:700;color:var(--blue);}
.or-stats .b{font-size:10px;color:#a0b4d0;}
.st{font-size:10px;padding:3px 9px;border-radius:999px;font-weight:700;}
.st-on{background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);}
.st-off{background:rgba(255,255,255,0.04);color:#a0b4d0;border:1px solid var(--border);}
.or-btns{display:flex;gap:5px;}
.mb{border:1px solid var(--border2);background:transparent;border-radius:7px;padding:4px 10px;font-size:11px;cursor:pointer;color:#a0b4d0;font-family:inherit;}
.mb.b{background:var(--blue);color:#020e1a;border-color:var(--blue);font-weight:700;}
.mb.r{background:var(--red-bg);color:var(--red);border-color:rgba(248,113,113,0.22);}
.modal-bg{position:fixed;inset:0;background:rgba(5,8,20,0.88);backdrop-filter:blur(7px);display:none;align-items:center;justify-content:center;padding:20px;z-index:200;}
.modal-bg.open{display:flex;}
.modal{background:#0d1b3e;border:1px solid var(--blue-border);border-radius:22px;padding:26px;max-width:420px;width:100%;}
.m-hdr{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.m-title{font-size:15px;font-weight:700;color:#fff;}
.m-sub{font-size:11px;color:#a0b4d0;margin-top:2px;}
.m-close{background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:8px;padding:5px 10px;cursor:pointer;font-size:14px;color:#a0b4d0;font-family:inherit;}
.m-info{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:12px;padding:13px 15px;margin-bottom:15px;}
.m-info-row{display:flex;justify-content:space-between;font-size:12px;color:#c0cfe8;margin-bottom:7px;}
.m-price-now{font-size:24px;font-weight:700;color:var(--blue);}
.m-price-orig{font-size:12px;color:#556b88;text-decoration:line-through;margin-left:6px;}
.m-disc{font-size:11px;background:var(--green-bg);color:var(--green);border-radius:6px;padding:2px 8px;font-weight:700;margin-left:6px;}
.m-fields{display:flex;flex-direction:column;gap:9px;margin-bottom:14px;}
.m-input{background:rgba(255,255,255,0.06);border:1px solid var(--border2);border-radius:10px;padding:10px 13px;font-size:13px;color:#fff;font-family:inherit;width:100%;}
.m-input::placeholder{color:#6a7a99;}
.m-input:focus{outline:none;border-color:var(--blue);}
.m-confirm{width:100%;background:var(--blue);color:#020e1a;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.m-confirm:hover{opacity:.85;}
.m-success{text-align:center;padding:10px 0;}
.big-e{font-size:44px;margin-bottom:14px;}
.m-ok-title{font-size:18px;font-weight:700;color:#fff;margin-bottom:8px;}
.m-ok-sub{font-size:13px;color:#c0cfe8;line-height:1.65;}
.m-ok-box{background:var(--green-bg);border:1px solid var(--green-border);border-radius:10px;padding:12px 14px;margin-top:14px;font-size:13px;color:var(--green);font-weight:600;}
.toast{position:fixed;bottom:24px;right:24px;background:#0d1b3e;border:1px solid var(--green-border);border-radius:14px;padding:14px 18px;font-size:13px;color:var(--green);font-weight:600;z-index:300;display:none;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);}
.toast.show{display:flex;}
</style>

</head><body><div class="app">
<div class="orb1"></div><div class="orb2"></div>

<nav class="nav">
  <div class="nav-logo">
    <div class="logo-mark">D</div>
    <span class="logo-name">DoMore</span>
    <span class="logo-ch">Switzerland</span>
  </div>
  <div class="nav-center">
    <button class="ntab active" onclick="switchTab(&#39;discover&#39;)">🗺 Discover</button>
    <button class="ntab" onclick="switchTab(&#39;partner&#39;)">🤝 Partner Portal</button>
    <button class="ntab" onclick="switchTab(&#39;membership&#39;)">🎫 Membership</button>
  </div>
  <div class="nav-right">
    <div class="user-pill" onclick="toggleRole()">
      <div class="user-av" id="userAv" style="background:var(--green-bg);border:1px solid var(--green-border);color:var(--green)">S</div>
      <span id="userName">Student</span>
    </div>
    <span class="role-badge role-student" id="roleBadge" onclick="toggleRole()">Student ↔ Partner</span>
  </div>
</nav>

<div class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-badge">🎟 Student membership · Free during beta</div>
      <h1>Do more in Switzerland<br>up to <em>-50% off</em></h1>
      <p>Exclusive discounts for students — wellness, sport, casual &amp; more.<br>20 verified partners, 24 live offers. One discount per activity.</p>
      <div class="hero-btns">
        <button class="btn-blue" onclick="switchTab(&#39;discover&#39;)">Browse offers</button>
        <button class="btn-ghost" onclick="switchTab(&#39;partner&#39;)">Become a partner</button>
      </div>
    </div>
    <div class="hero-card">
      <div class="hc-top"><div><div class="hc-sub">Live platform</div><div class="hc-title">Simple, free, local</div></div><div class="shield">✓</div></div>
      <div class="hs-big"><div class="l">Membership fee</div><div class="v">FREE</div></div>
      <div class="hs-row">
        <div class="hs-sm"><div class="l">Max discount</div><div class="v" style="color:var(--blue)">-50%</div></div>
        <div class="hs-sm"><div class="l">Live offers</div><div class="v" id="heroCount">24</div></div>
      </div>
    </div>
  </div>
</div>

<!-- DISCOVER -->
<div id="tab-discover" class="main">
  <div class="stat-strip">
    <div class="sc"><div class="info"><div class="l">Active offers</div><div class="v" id="statTotal">24</div><div class="s">Updated in real time</div></div><div class="ico">📋</div></div>
    <div class="sc"><div class="info"><div class="l">Membership</div><div class="v" style="color:var(--green)">FREE</div><div class="s">During beta phase</div></div><div class="ico">🎫</div></div>
    <div class="sc"><div class="info"><div class="l">Partners</div><div class="v" id="statPartners">20</div><div class="s">Verified providers</div></div><div class="ico">🤝</div></div>
